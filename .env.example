DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Prefer a schema-owner connection here and a least-privilege application role in DATABASE_URL.
DATABASE_MIGRATION_URL=
# Set to true only when your Postgres host requires TLS and the URL does not include sslmode=require.
DATABASE_SSL=false
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=8000
DATABASE_STATEMENT_TIMEOUT_MS=7000

# Requests should arrive through Cloudflare on the canonical host in production.
ALLOWED_HOSTS=
TRUSTED_CLIENT_IP_HEADER=cf-connecting-ip
RATE_LIMIT_HASH_SECRET=
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
SITE_ANALYTICS_RATE_LIMIT_MAX=120
SITE_ANALYTICS_RATE_LIMIT_WINDOW_SECONDS=60

# Public site and Google readiness settings.
NEXT_PUBLIC_SITE_URL=https://brandd.co.uk
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Use Google Tag Manager if you want tags configured from GTM.
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
# Use direct gtag configuration if GTM is not configured.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
# Cloudflare Turnstile. Set both keys, then enable REQUIRE_TURNSTILE in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
REQUIRE_TURNSTILE=false
# Set true to disable first-party Postgres site analytics while leaving contact submissions enabled.
SITE_ANALYTICS_DISABLED=false
SITE_ANALYTICS_RETENTION_DAYS=395
CONTACT_RETENTION_DAYS=730

# Future offline/enhanced lead upload integration.
# As of 2026-07-03, new offline/enhanced lead uploads should be planned around
# Google's Data Manager API unless the Google Ads developer token is allowlisted
# for legacy Google Ads API conversion upload access.
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CONVERSION_ACTION_ID=
GOOGLE_DATA_MANAGER_API_ENABLED=false

# SendGrid contact form email notifications.
# Missing values skip email delivery, but the enquiry is still saved in Postgres.
SENDGRID_API_KEY=
CONTACT_EMAIL_TO=enquiries@brandd.co.uk
CONTACT_EMAIL_FROM="Brandd Solutions <enquiries@brandd.co.uk>"
# Protects POST /api/internal/contact-notifications for scheduled queue retries.
CONTACT_NOTIFICATION_WORKER_SECRET=

# Meta WhatsApp Cloud API contact form notifications.
# Keep false locally unless the Meta app, phone number, token and recipient are ready.
WHATSAPP_CONTACT_NOTIFICATIONS=false
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Use international format. The app strips spaces, dashes and a leading plus before sending.
WHATSAPP_RECIPIENT_PHONE=
# Recommended for production: an approved template with body variables:
# {{1}} enquiry id, {{2}} name, {{3}} email, {{4}} service focus, {{5}} message.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_GB
