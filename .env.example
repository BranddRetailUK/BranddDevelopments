DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Set to true only when your Postgres host requires TLS and the URL does not include sslmode=require.
DATABASE_SSL=false
DATABASE_POOL_MAX=5

# Meta WhatsApp Cloud API contact form notifications.
# Keep false locally unless the Meta app, phone number, token and recipient are ready.
WHATSAPP_CONTACT_NOTIFICATIONS=false
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Use international format. The app strips spaces, dashes and a leading plus before sending.
WHATSAPP_RECIPIENT_PHONE=
# Recommended for production: an approved template with body variables:
# {{1}} enquiry id, {{2}} name, {{3}} email, {{4}} service focus, {{5}} message.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_GB
